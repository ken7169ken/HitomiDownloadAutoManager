{
  "manifest_version": 3,
  "name": "Hitomi Rescue Watch",
  "version": "0.3",
  "description": "Hitomi楽園のらくらく同人活動",

  "permissions": [
    "tabs",
    "contextMenus"
  ],

  "host_permissions": [
    "https://hitomi.la/*",
    "https://*.hitomi.la/*",
    "http://127.0.0.1:18765/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://hitomi.la/*",
        "https://*.hitomi.la/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}